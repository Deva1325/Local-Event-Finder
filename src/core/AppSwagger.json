{
  "openapi": "3.0.0",
  "info": {
    "title": "Local Event Finder API",
    "version": "1.0.0",
    "description": "API documentation for Local Event Finder project"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Local developement server"
    },
    {
      "url": "http://192.168.1.103:3000/api",
      "description": "Shared network server 192.168.1.103"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {

    "/auth/register": {
      "post": {
        "summary": "Register new user",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  },
                  "phone": {
                    "type": "string"
                  },
                  "role" :{
                    "type": "string", 
                    "enum": ["user", "organizer"], 
                    "description": "Defaults to 'user' if not provided"
                  }
                },
                "required": ["name", "email", "password"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully"
          }
        }
      }
    },

    "/auth/verify-email": {
      "get": {
        "summary": "Verify user email",
        "tags": ["Authentication"],
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Email verified successfully"
          }
        }
      }
    },

    "/auth/login": {
      "post": {
        "summary": "User login",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          }
        }
      }
    },

    "/auth/refresh-token": {
      "post": {
        "summary": "Generate new access token using refresh token",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "refresh_token": {
                    "type": "string"
                  }
                },
                "required": ["refresh_token"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New access token generated"
          }
        }
      }
    },

    "/auth/logout": {
      "post": {
        "summary": "Logout user",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "refresh_token": {
                    "type": "string"
                  }
                },
                "required": ["refresh_token"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logout successful"
          }
        }
      }
    },

    "/auth/forgot-password": {
      "post": {
        "summary": "Send password reset email",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string"
                  }
                },
                "required": ["email"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reset password link sent"
          }
        }
      }
    },

    "/auth/reset-password": {
      "post": {
        "summary": "Reset user password",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": ["token", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset successful"
          }
        }
      }
    },

    "/auth/profile": {
      "get": {
        "summary": "Get logged in user profile",
        "tags": ["Authentication"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User profile fetched successfully"
          }
        }
      }
    },

    "/categories": {
      "post": {
        "summary": "Create category (Admin only)",
        "tags": ["Category"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  }
                },
                "required": ["name"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Category created successfully"
          }
        }
      },

      "get": {
        "summary": "Get all categories",
        "tags": ["Category"],
        "responses": {
          "200": {
            "description": "Categories fetched successfully"
          }
        }
      }
    },

    "/categories/{id}": {
      "get": {
        "summary": "Get category by ID",
        "tags": ["Category"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Category fetched successfully"
          }
        }
      },

      "put": {
        "summary": "Update category",
        "tags": ["Category"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string",
                    "enum": ["active", "inactive"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Category updated successfully"
          }
        }
      },

      "delete": {
        "summary": "Delete category",
        "tags": ["Category"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Category deleted successfully"
          }
        }
      }
    },

    "/events": {
      "post": {
        "summary": "Create new event (Organizer only)",
        "tags": ["Events"],
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "category_id": { "type": "integer" },
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "location": { "type": "string" },
                  "start_date": { "type": "string", "format": "date" },
                  "end_date": { "type": "string", "format": "date" },
                  "event_time": { "type": "string" },
                  "ticket_price": { "type": "number" },
                  "total_seats": { "type": "integer" },
                  "booking_start_date": { "type": "string", "format": "date", "description": "Date when ticket sales start" },
                  "booking_end_date": { "type": "string", "format": "date", "description": "Date when ticket sales end" },
                  "image": { "type": "string", "format": "binary" }
                },
                "required": [
                  "category_id", 
                  "title", 
                  "start_date", 
                  "ticket_price", 
                  "total_seats", 
                  "booking_start_date", 
                  "booking_end_date"
                ]
              }
            }
          }
        },
        "responses": { 
          "201": { "description": "Event created successfully in draft status" },
          "400": { "description": "Validation error (e.g. end date before start date)" }
        }
      },
      "get": {
        "summary": "Get all events",
        "tags": ["Events"],
        "parameters": [
          { "name": "category_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "sort", "in": "query", "schema": { "type": "string", "enum": ["asc", "desc"] }, "description": "Sort by start_date" }
        ],
        "responses": { "200": { "description": "Success" } }
      }
    },

    "/events/{id}": {
      "get": {
        "summary": "Get event by ID with average rating",
        "tags": ["Events"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Success - returns event details with average_rating and totalReviews" } }
      },
      "put": {
        "summary": "Update event (Organizer only - Draft status only)",
        "tags": ["Events"],
        "security": [{"bearerAuth": []}],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "location": { "type": "string" },
                  "start_date": { "type": "string", "format": "date" },
                  "end_date": { "type": "string", "format": "date" },
                  "event_time": { "type": "string" },
                  "ticket_price": { "type": "number" },
                  "total_seats": { "type": "integer" },
                  "image": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": { 
          "200": { "description": "Event updated successfully" },
          "400": { "description": "Cannot update: status not draft or seat reduction conflict" },
          "403": { "description": "Unauthorized to update this event" }
        }
      },
      "delete": {
        "summary": "Delete event",
        "tags": ["Events"],
        "security": [{"bearerAuth": []}],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { 
          "200": { "description": "Event deleted successfully" },
          "403": { "description": "Unauthorized to delete this event" }
        }
      }
    },

    "/bookings": {
      "post": {
        "summary": "Book tickets for an event",
        "tags": ["Bookings"],
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "event_id": { "type": "integer" },
                  "ticket_quantity": { "type": "integer" }
                },
                "required": ["event_id", "ticket_quantity"]
              }
            }
          }
        },
        "responses": { "201": { "description": "Booking created" } }
      }
    },
    
    "/bookings/{id}/cancel": {
      "put": {
        "summary": "Cancel a booking",
        "tags": ["Bookings"],
        "security": [{"bearerAuth": []}],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Booking cancelled" } }
      }
    },
    "/reviews": {
      "post": {
        "summary": "Add a review for an event",
        "tags": ["Reviews"],
        "security": [{"bearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "event_id": { "type": "integer" },
                  "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "review_text": { "type": "string" }
                },
                "required": ["event_id", "rating"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Review added successfully" },
          "400": { "description": "Validation error or duplicate review" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/reviews/event/{event_id}": {
      "get": {
        "summary": "Get all reviews for a specific event",
        "tags": ["Reviews"],
        "parameters": [
          {
            "name": "event_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Reviews fetched successfully" },
          "404": { "description": "Event not found" }
        }
      }
    },
    "/reviews/{review_id}": {
      "put": {
        "summary": "Update an existing review",
        "tags": ["Reviews"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "review_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
                  "review_text": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Review updated successfully" },
          "404": { "description": "Review not found or unauthorized" }
        }
      },
      "delete": {
        "summary": "Delete a review",
        "tags": ["Reviews"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "review_id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Review deleted successfully" },
          "404": { "description": "Review not found" }
        }
      }
    },
    "/admin/organizer/{id}/approve": {
      "put": {
        "summary": "Approve an organizer application",
        "tags": ["Admin"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Organizer approved successfully" },
          "400": { "description": "User is not an organizer or already processed" },
          "404": { "description": "User not found" }
        }
      }
    },

    "/admin/organizer/{id}/reject": {
      "put": {
        "summary": "Reject an organizer application",
        "tags": ["Admin"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Organizer rejected successfully" },
          "400": { "description": "User is not an organizer or already processed" },
          "404": { "description": "User not found" }
        }
      }
    },

    "/organizer/dashboard": {
      "get": {
        "summary": "Get comprehensive dashboard statistics for the logged-in organizer",
        "tags": ["Organizer"],
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {
            "description": "Dashboard statistics fetched successfully",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": "Details fetched successfully!",
                  "data": {
                    "total_Events": 5,
                    "total_Sold_Tickets": 120,
                    "total_revenue": 5000.50,
                    "upcoming_events": [],
                    "pastEvents": []
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized User" },
          "403": { "description": "Forbidden - Only organizers allowed" }
        }
      }
    }
    

  }
}