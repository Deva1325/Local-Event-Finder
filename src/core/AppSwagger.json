            "description": "Invalid event ID"
          },
          "403": {
            "description": "Unauthorized access"
          },
          "404": {
            "description": "Event not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/reviews": {
      "post": {
        "summary": "Add a review for an event",
        "tags": [
          "Reviews"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "event_id": {
                    "type": "integer"
                  },
                  "rating": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                  },
                  "review_text": {
                    "type": "string"
                  }
                },
                "required": [
                  "event_id",
                  "rating"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Review added successfully"
          },
          "400": {
            "description": "Validation error or duplicate review"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/reviews/event/{event_id}": {
      "get": {
        "summary": "Get all reviews for a specific event",
